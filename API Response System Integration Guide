### Step 3: Create GlobalExceptionHandler

#### GlobalExceptionHandler.java
```java
package com.yourcompany.exception;

import com.yourcompany.dto.*;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ControllerAdvice;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.validation.ObjectError;
import java.util.List;
import java.util.stream.Collectors;

@ControllerAdvice
public class GlobalExceptionHandler {
    
    @ExceptionHandler(ServiceException.class)
    public ResponseEntity<ApiResponse> handleServiceException(ServiceException ex) {
        List<ApiErrorItem> errorItems = null;
        
        if (ex.getValidationErrors() != null) {
            errorItems = ex.getValidationErrors().stream()
                .map(this::convertToApiErrorItem)
                .collect(Collectors.toList());
        }
        
        ApiError apiError = new ApiError(
            ex.getCode().getCode(),
            ex.getResource() != null ? ex.getResource() : ex.getMessage(),
            errorItems
        );
        
        ApiResponse response = new ApiResponse(
            ex.getStatus(),
            ex.getResource() != null ? ex.getResource() : ex.getMessage(),
            apiError
        );
        
        return ResponseEntity.status(ex.getStatus()).body(response);
    }
    
    @ExceptionHandler(Exception.class)
    public ResponseEntity<ApiResponse> handleDefaultException(Exception ex) {
        ApiError apiError = new ApiError(
            ExceptionErrorEnum.INTERNAL_ERROR.getCode(),
            "An unexpected error occurred",
            null
        );
        
        ApiResponse response = new ApiResponse(
            HttpStatus.INTERNAL_SERVER_ERROR,
            "Internal server error",
            apiError
        );
        
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
    }
    
    private ApiErrorItem convertToApiErrorItem(ObjectError error) {
        String field = error.getObjectName();
        if (error.getArguments() != null && error.getArguments().length > 1) {
            field = (String) error.getArguments()[1];
        }
        
        return new ApiErrorItem(
            field,
            error.getDefaultMessage(),
            ExceptionErrorEnum.VALIDATION_ERROR.getCode()
        );
    }
}
```

### Step 4: Controller Implementation

#### EmployeeController.java
```java
package com.yourcompany.controller;

import com.yourcompany.dto.ApiResponse;
import com.yourcompany.exception.ServiceException;
import com.yourcompany.exception.ExceptionErrorEnum;
import com.yourcompany.dto.EmployeeDTO;
import com.yourcompany.service.EmployeeService;
import com.yourcompany.validator.EmployeeValidator;
import com.yourcompany.mapper.EmployeeMapper;
import com.yourcompany.service.EmailService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.validation.BindingResult;
import org.springframework.web.bind.annotation.*;

import java.text.ParseException;

@RestController
@RequestMapping("/api/v1/employees")
public class EmployeeController {
    
    private static final Logger logger = LoggerFactory.getLogger(EmployeeController.class);
    
    @Autowired
    private EmployeeValidator employeeValidator;
    
    @Autowired
    private EmployeeService employeeService;
    
    @Autowired
    private EmailService emailService;
    
    @PostMapping
    public ResponseEntity<ApiResponse> createEmployee(@RequestBody EmployeeDTO employeeDto, 
                                                     BindingResult bindingResult) throws ServiceException, ParseException {
        
        logger.debug("POST /api/v1/employees");
        
        // Validate using EmployeeValidator
        employeeValidator.validate(employeeDto, bindingResult);

        if (bindingResult.hasErrors()) {
            throw new ServiceException("employees", HttpStatus.BAD_REQUEST, ExceptionErrorEnum.EMPLOYEE_VALIDATION_ERROR, bindingResult.getAllErrors());
        }

        // Validate duplicate DNI
        Long count = employeeService.getCountEmployeeByDNI(employeeDto.getDni(), null);
        if (count > 0) {
            throw new ServiceException("employees", HttpStatus.CONFLICT, ExceptionErrorEnum.EMPLOYEE_DNI_EXISTS);
        }

        Employee employee = employeeService.createEmployee(employeeDto);

        // Send email only on creation
        emailService.sendWelcomeEmail(employeeService.getEmployeeById(employee.getId()));

        return ResponseEntity.status(HttpStatus.CREATED)
            .body(new ApiResponse(HttpStatus.CREATED, null, EmployeeMapper.toDTO(employee)));
    }
    
    @GetMapping("/{id}")
    public ResponseEntity<ApiResponse> getEmployee(@PathVariable Long id) throws ServiceException {
        Employee employee = employeeService.getById(id);
        return ResponseEntity.ok(new ApiResponse(HttpStatus.OK, null, EmployeeMapper.toDTO(employee)));
    }
    
    @PutMapping("/{id}")
    public ResponseEntity<ApiResponse> updateEmployee(@PathVariable Long id, 
                                                     @RequestBody EmployeeDTO employeeDto,
                                                     BindingResult bindingResult) throws ServiceException, ParseException {
        
        logger.debug("PUT /api/v1/employees/{}", id);
        
        // Validate using EmployeeValidator
        employeeValidator.validate(employeeDto, bindingResult);

        if (bindingResult.hasErrors()) {
            throw new ServiceException("employees", HttpStatus.BAD_REQUEST, ExceptionErrorEnum.EMPLOYEE_VALIDATION_ERROR, bindingResult.getAllErrors());
        }

        // Validate duplicate DNI (excluding current employee)
        Long count = employeeService.getCountEmployeeByDNI(employeeDto.getDni(), id);
        if (count > 0) {
            throw new ServiceException("employees", HttpStatus.CONFLICT, ExceptionErrorEnum.EMPLOYEE_DNI_EXISTS);
        }

        Employee employee = employeeService.updateEmployee(id, employeeDto);

        return ResponseEntity.ok(new ApiResponse(HttpStatus.OK, null, EmployeeMapper.toDTO(employee)));
    }
    
    @DeleteMapping("/{id}")
    public ResponseEntity<ApiResponse> deleteEmployee(@PathVariable Long id) throws ServiceException {
        employeeService.deleteEmployee(id);
        return ResponseEntity.ok(new ApiResponse(HttpStatus.OK, "Employee deleted successfully", null));
    }
    
    @GetMapping
    public ResponseEntity<ApiResponse> getAllEmployees(@RequestParam(defaultValue = "0") Integer page,
                                                       @RequestParam(defaultValue = "20") Integer size,
                                                       @RequestParam(defaultValue = "name") String sort) {
        
        logger.debug("GET /api/v1/employees");
        
        Page<Employee> employees = employeeService.getAllEmployees(page, size, sort);
        PaginationInfo paginationInfo = new PaginationInfo(
            employees.getNumber(),
            employees.getTotalPages(),
            employees.getTotalElements(),
            employees.getSize(),
            employees.isFirst(),
            employees.isLast()
        );
        
        return ResponseEntity.ok(new ApiResponse(
            employees.getContent().stream()
                .map(EmployeeMapper::toDTO)
                .collect(Collectors.toList()),
            paginationInfo
        ));
    }
}
```

### Step 5: Service Layer Implementation

#### EmployeeService.java
```java
package com.yourcompany.service;

import com.yourcompany.exception.ServiceException;
import com.yourcompany.exception.ExceptionErrorEnum;
import com.yourcompany.dto.EmployeeDTO;
import com.yourcompany.entity.Employee;
import com.yourcompany.repository.EmployeeRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.stereotype.Service;

import java.text.ParseException;

@Service
public class EmployeeService {
    
    @Autowired
    private EmployeeRepository employeeRepository;
    
    public Employee createEmployee(EmployeeDTO dto) throws ServiceException, ParseException {
        try {
            Employee employee = EmployeeMapper.toEntity(dto);
            return employeeRepository.save(employee);
        } catch (Exception e) {
            throw new ServiceException("Error creating employee", HttpStatus.INTERNAL_SERVER_ERROR, ExceptionErrorEnum.DATABASE_ERROR);
        }
    }
    
    public Employee updateEmployee(Long id, EmployeeDTO dto) throws ServiceException, ParseException {
        Employee existingEmployee = getById(id);
        
        // Update fields
        existingEmployee.setName(dto.getName());
        existingEmployee.setEmail(dto.getEmail());
        existingEmployee.setDni(dto.getDni());
        
        try {
            return employeeRepository.save(existingEmployee);
        } catch (Exception e) {
            throw new ServiceException("Error updating employee", HttpStatus.INTERNAL_SERVER_ERROR, ExceptionErrorEnum.DATABASE_ERROR);
        }
    }
    
    public Employee getById(Long id) throws ServiceException {
        return employeeRepository.findById(id)
            .orElseThrow(() -> new ServiceException("employees", HttpStatus.NOT_FOUND, ExceptionErrorEnum.EMPLOYEE_NOT_FOUND));
    }
    
    public Long getCountEmployeeByDNI(String dni, Long excludeId) {
        if (excludeId != null) {
            return employeeRepository.countByDniAndIdNot(dni, excludeId);
        }
        return employeeRepository.countByDni(dni);
    }
    
    public void deleteEmployee(Long id) throws ServiceException {
        Employee employee = getById(id);
        employeeRepository.delete(employee);
    }
    
    public Page<Employee> getAllEmployees(Integer page, Integer size, String sort) {
        Pageable pageable = PageRequest.of(page, size, Sort.by(sort));
        return employeeRepository.findAll(pageable);
    }
}
```

