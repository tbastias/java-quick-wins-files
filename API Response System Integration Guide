### Step 2: Create Exception Classes

#### ServiceException.java
```java
package com.yourcompany.exception;

import org.springframework.http.HttpStatus;
import org.springframework.validation.ObjectError;
import java.util.List;
import java.util.Map;

public class ServiceException extends Exception {
    private final HttpStatus status;
    private final ExceptionErrorEnum code;
    private final String resource;
    private final List<ObjectError> validationErrors;
    private final Map<String, Object> data;
    
    public ServiceException(String resource, HttpStatus status, ExceptionErrorEnum code, List<ObjectError> validationErrors) {
        super(resource);
        this.resource = resource;
        this.status = status;
        this.code = code;
        this.validationErrors = validationErrors;
        this.data = null;
    }
    
    public ServiceException(String resource, HttpStatus status, ExceptionErrorEnum code) {
        this(resource, status, code, null);
    }
    
    public ServiceException(String message, HttpStatus status, ExceptionErrorEnum code, Map<String, Object> data) {
        super(message);
        this.resource = null;
        this.status = status;
        this.code = code;
        this.validationErrors = null;
        this.data = data;
    }
    
    // Getters...
    public HttpStatus getStatus() { return status; }
    public ExceptionErrorEnum getCode() { return code; }
    public String getResource() { return resource; }
    public List<ObjectError> getValidationErrors() { return validationErrors; }
    public Map<String, Object> getData() { return data; }
}
```

